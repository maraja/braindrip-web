---
import { courses } from '../../data/courses';
const totalConcepts = courses.reduce((sum, c) => sum + c.conceptCount, 0);
---

<footer class="mt-24 border-t border-cream-300/70">
  <div class="mx-auto max-w-[1200px] px-6 py-10">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <p class="font-serif text-base font-semibold text-forest-700 mb-1">Brain Drip</p>
        <p class="text-sm text-forest-400">Concept-driven learning for AI and machine learning</p>
      </div>
      <div class="text-xs font-mono text-forest-400 flex items-center gap-3 tracking-wide">
        <span>{totalConcepts} concepts</span>
        <span class="w-1 h-1 rounded-full bg-cream-300"></span>
        <span>{courses.length} courses</span>
        <span class="w-1 h-1 rounded-full bg-cream-300"></span>
        <span>Built with Astro</span>
      </div>
    </div>
  </div>
</footer>
