---
import type { CourseInfo } from '../../data/courses';

interface Props {
  course: CourseInfo;
  firstModuleSlug?: string;
}

const { course, firstModuleSlug } = Astro.props;
---

<section class="relative py-16 sm:py-20 overflow-hidden">
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-20 left-1/3 w-[400px] h-[400px] bg-sage/[0.04] rounded-full blur-[100px]"></div>
    <div class="absolute -bottom-10 right-1/4 w-[300px] h-[300px] bg-rust/[0.03] rounded-full blur-[80px]"></div>
  </div>

  <div class="mx-auto max-w-[680px] text-center px-6">
    <div class="inline-flex items-center gap-2 rounded-full border border-sage/20 bg-sage/[0.06] px-4 py-1.5 text-[12px] font-mono font-medium text-sage-dark mb-8 tracking-wide">
      <span class="w-1.5 h-1.5 rounded-full bg-sage"></span>
      {course.conceptCount} concepts &middot; {course.moduleCount} {course.moduleCount === 1 ? 'module' : 'modules'}
    </div>

    <div class="text-4xl mb-4">{course.icon}</div>

    <h1 class="font-serif text-[2rem] sm:text-[2.75rem] font-bold text-forest-700 leading-[1.1] tracking-tight mb-6">
      {course.title}
    </h1>

    <p class="text-lg text-forest-500 leading-relaxed max-w-[520px] mx-auto mb-10">
      {course.description}
    </p>

    {firstModuleSlug && (
      <a
        href={`/courses/${course.slug}/modules/${firstModuleSlug}`}
        class="inline-flex items-center gap-2 rounded-lg bg-forest-700 px-6 py-3 text-[15px] font-medium text-cream-100 transition-all hover:bg-forest-600 hover:shadow-md no-underline"
      >
        Start Module 01
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    )}
  </div>
</section>
