---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import { blueprints } from '../../../data/blueprints';
import { getBlueprintModules } from '../../../data/blueprint-modules';
import { getModuleSteps } from '../../../utils/blueprint-steps';

const difficultyColors: Record<string, string> = {
  beginner: 'bg-sage/12 text-sage-dark',
  intermediate: 'bg-gold/15 text-forest-600',
  advanced: 'bg-rust/12 text-rust',
};

const difficultyLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

export async function getStaticPaths() {
  const paths = [];
  for (const bp of blueprints) {
    const modules = getBlueprintModules(bp.slug);
    const firstModule = modules[0];
    let steps: any[] = [];
    if (firstModule) {
      steps = await getModuleSteps(bp.slug, firstModule.slug);
    }
    paths.push({
      params: { blueprint: bp.slug },
      props: { blueprint: bp, steps },
    });
  }
  return paths;
}

const { blueprint, steps } = Astro.props;
const modules = getBlueprintModules(blueprint.slug);
const firstModule = modules[0];
const firstStep = steps[0];
---

<BaseLayout title={blueprint.title} description={blueprint.description}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative py-16 sm:py-20 overflow-hidden">
      <div class="absolute inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-20 left-1/3 w-[400px] h-[400px] bg-rust/[0.04] rounded-full blur-[100px]"></div>
        <div class="absolute -bottom-10 right-1/4 w-[300px] h-[300px] bg-gold/[0.04] rounded-full blur-[80px]"></div>
      </div>

      <div class="mx-auto max-w-[680px] text-center px-6">
        <div class="inline-flex items-center gap-2 rounded-full border border-rust/20 bg-rust/[0.06] px-4 py-1.5 text-[12px] font-mono font-medium text-rust mb-8 tracking-wide">
          <span class="w-1.5 h-1.5 rounded-full bg-rust"></span>
          Blueprint &middot; {blueprint.stepCount} steps &middot;
          <span class={difficultyColors[blueprint.difficulty].replace('bg-', '').replace(/\/.*/, '')}>
            {difficultyLabels[blueprint.difficulty]}
          </span>
        </div>

        <div class="text-4xl mb-4">{blueprint.icon}</div>

        <h1 class="font-serif text-[2rem] sm:text-[2.75rem] font-bold text-forest-700 leading-[1.1] tracking-tight mb-6">
          {blueprint.title}
        </h1>

        <p class="text-lg text-forest-500 leading-relaxed max-w-[520px] mx-auto mb-10">
          {blueprint.description}
        </p>

        {firstStep && firstModule && (
          <a
            href={`/blueprints/${blueprint.slug}/${firstModule.slug}/${firstStep.slug}`}
            class="inline-flex items-center gap-2 rounded-lg bg-rust px-6 py-3 text-[15px] font-medium text-cream-100 transition-all hover:bg-rust/90 hover:shadow-md no-underline"
          >
            Start Building
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        )}
      </div>
    </section>

    <!-- Steps -->
    <section class="mx-auto max-w-[900px] px-6 pb-24">
      <div class="mb-12">
        <h2 class="font-serif text-2xl font-bold text-forest-700 mb-2">What You'll Build</h2>
        <p class="text-forest-500 text-[15px] max-w-lg">
          Follow these steps from start to finish. Each one builds on the last.
        </p>
      </div>

      <div class="space-y-3">
        {steps.map((step: any, i: number) => (
          <a
            href={`/blueprints/${blueprint.slug}/${firstModule?.slug}/${step.slug}`}
            class="group flex items-start gap-5 rounded-xl border border-cream-300 bg-cream-50/80 p-5 sm:p-6 transition-all hover:border-rust/30 hover:bg-white hover:shadow-sm no-underline"
          >
            <div class="flex-shrink-0 w-11 h-11 sm:w-12 sm:h-12 rounded-xl bg-rust/[0.08] flex items-center justify-center text-sm font-mono font-bold text-rust">
              {String(i + 1).padStart(2, '0')}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                <span class="text-[11px] font-mono font-medium text-forest-400">Step {String(i + 1).padStart(2, '0')}</span>
                {i === 0 && (
                  <span class="inline-flex items-center rounded-full bg-rust/8 px-2.5 py-0.5 text-[10px] font-semibold text-rust tracking-wide">
                    Start here
                  </span>
                )}
              </div>
              <h3 class="font-serif text-base sm:text-lg font-semibold text-forest-700 group-hover:text-rust transition-colors leading-snug">
                {step.slug.replace(/^\d+-/, '').replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}
              </h3>
            </div>
            <svg class="w-5 h-5 text-forest-400/30 group-hover:text-rust group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
